---
import Layout from '@/layouts/main.astro';
import { Button } from '@/components/ui/button';
import { ThemeToggle } from '@/components/react/ThemeToggle';
import { FileQuestion, MoveLeft, Stethoscope } from 'lucide-react';
---

<Layout title="404 - Página no encontrada | Servicio Luna">
  <main class="h-screen w-full flex items-center justify-center bg-background overflow-hidden relative">
    
    {/* ── Background Aesthetics ── */}
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-primary/10 blur-[100px] pointer-events-none" />
    <div class="absolute bottom-[-10%] right-[-10%] w-[30%] h-[30%] rounded-full bg-accent-foreground/5 blur-[80px] pointer-events-none" />
    <div class="absolute inset-0 bg-size-[40px_40px] bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] mask-[radial-gradient(ellipse_60%_60%_at_50%_50%,#000_20%,transparent_100%)] pointer-events-none opacity-20" />

    {/* ThemeToggle */}
    <div class="absolute top-4 right-4 z-50">
      <ThemeToggle client:load />
    </div>

    <div class="relative z-10 max-w-2xl px-6 text-center animate-fade-in-up">
      {/* Icon Badge */}
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-primary/10 border border-primary/20 mb-8 backdrop-blur-sm">
        <FileQuestion className="w-10 h-10 text-primary" />
      </div>

      <h1 class="font-heading text-8xl font-bold tracking-tighter text-foreground mb-4">
        4<span class="text-transparent bg-clip-text bg-linear-to-br from-primary to-accent-foreground">0</span>4
      </h1>

      <h2 class="font-heading text-3xl font-bold text-foreground mb-4 leading-tight">
        Diagnóstico: Página No Encontrada
      </h2>

      <p class="font-body text-muted-foreground text-lg leading-relaxed max-w-md mx-auto mb-10">
        Parece que la ruta que intentas acceder no existe en nuestro sistema de evaluación clínica. Es posible que el enlace esté roto o haya sido trasladado.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/">
          <Button size="lg" className="px-8 font-heading font-semibold bg-primary hover:bg-primary/90 text-primary-foreground h-12 shadow-lg transition-transform hover:scale-105 active:scale-95">
            <MoveLeft className="w-4 h-4 mr-2" />
            Volver al Inicio
          </Button>
        </a>
        
        <div class="flex items-center gap-2 px-4 py-2 rounded-full border border-border/60 bg-muted/50 backdrop-blur-sm self-center sm:self-auto">
          <Stethoscope className="w-4 h-4 text-muted-foreground" />
          <span class="font-heading text-xs font-medium text-muted-foreground">Servicio Luna Evaluator</span>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
